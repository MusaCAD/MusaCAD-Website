---
// Footer — full-width "drawing sheet" footer with a faint blueprint-grid detail.
// Quiet and elegant: brand + tagline on the left, two link columns, and a
// hairline bottom bar with license, copyright, and a small mono CAD detail.
// No JS — purely presentational (the global [data-donate] handler is not needed here).
import {
  REPO_URL,
  RELEASES_URL,
  ARCHITECTURE_URL,
  BUILD_URL,
  LICENSE,
} from '../data/site';

// Internal anchor links (Product). Stay on-page.
const product = [
  { label: 'Features', href: '#features' },
  { label: 'Performance', href: '#performance' },
  { label: 'Architecture', href: '#architecture' },
  { label: 'Download', href: '#download' },
];

// External project links — all open in a new tab with rel="noopener".
const project = [
  { label: 'GitHub', href: REPO_URL },
  { label: 'Releases', href: RELEASES_URL },
  { label: 'Architecture docs', href: ARCHITECTURE_URL },
  { label: 'Build guide', href: BUILD_URL },
];
---

<footer class="relative border-t border-line bg-paper">
  <!-- Faint blueprint grid — decorative, behind content, fading toward the top. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-[0.5]"
    style="
      background-image:
        linear-gradient(to right, var(--color-grid, #cfd8e3) 1px, transparent 1px),
        linear-gradient(to bottom, var(--color-grid, #cfd8e3) 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: linear-gradient(to bottom, transparent, black 120px);
      -webkit-mask-image: linear-gradient(to bottom, transparent, black 120px);
    "
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-5 py-16 sm:px-8 sm:py-20">
    <!-- Top: brand block + link columns -->
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr] md:gap-8">
      <!-- Brand -->
      <div class="max-w-sm">
        <a href={import.meta.env.BASE_URL} class="group inline-flex items-center gap-2.5" aria-label="Musa CAD home">
          <img
            src={`${import.meta.env.BASE_URL}icon-192.png`}
            alt=""
            width="28"
            height="28"
            class="h-7 w-7 transition-transform duration-300 group-hover:rotate-[-6deg]"
          />
          <span class="font-display text-[1.15rem] font-semibold tracking-tight text-ink">
            Musa<span class="text-accent">CAD</span>
          </span>
        </a>

        <p class="mt-4 font-mono text-xs uppercase tracking-[0.18em] text-ink-faint">
          CAD that moves at 144 Hz.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-ink-soft">
          A high-performance, multi-threaded 2D CAD engine in modern C++23.
          GPU-accelerated, data-oriented, clone-and-build clean.
        </p>
      </div>

      <!-- Product column (on-page anchors) -->
      <nav aria-label="Product">
        <h2 class="font-mono text-xs uppercase tracking-[0.22em] text-ink-faint">
          Product
        </h2>
        <ul class="mt-4 space-y-2.5">
          {
            product.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-ink-soft transition-colors hover:text-ink"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Project column (external) -->
      <nav aria-label="Project">
        <h2 class="font-mono text-xs uppercase tracking-[0.22em] text-ink-faint">
          Project
        </h2>
        <ul class="mt-4 space-y-2.5">
          {
            project.map((l) => (
              <li>
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener"
                  class="group inline-flex items-center gap-1.5 text-sm text-ink-soft transition-colors hover:text-ink"
                >
                  {l.label}
                  <svg
                    viewBox="0 0 24 24"
                    class="h-3 w-3 text-ink-faint transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    aria-hidden="true"
                  >
                    <path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Hairline divider with a small dimension-tick CAD detail -->
    <div class="mt-14 flex items-center gap-3" aria-hidden="true">
      <span class="h-1.5 w-1.5 rotate-45 border border-accent"></span>
      <span class="h-px flex-1 bg-line-strong"></span>
      <span class="font-mono text-[0.7rem] tracking-wider text-ink-faint">@0,0</span>
      <span class="h-px w-8 bg-line-strong"></span>
    </div>

    <!-- Bottom bar: copyright, license, mono CAD detail -->
    <div
      class="mt-6 flex flex-col gap-3 text-xs text-ink-faint sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="font-mono">© 2026 Musa CAD</p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 font-mono">
        <a
          href={REPO_URL}
          target="_blank"
          rel="noopener"
          class="transition-colors hover:text-ink-soft"
        >
          {LICENSE}
        </a>
        <span class="hidden h-3 w-px bg-line-strong sm:inline-block"></span>
        <span class="text-ink-faint">@dist&lt;angle</span>
      </div>
    </div>
  </div>
</footer>
