---
// Sticky navbar — turns to glass on scroll. Logo + wordmark, anchored nav,
// GitHub (with build-time star count), Releases, and the accent Donate CTA.
import {
  REPO_URL,
  RELEASES_URL,
  LATEST_RELEASE,
  fetchStars,
  formatStars,
} from '../data/site';

const base = import.meta.env.BASE_URL;

// On the home page keep pure hash links (smooth-scrolled by Lenis); on other
// routes (e.g. /donate) point back to the home page's sections.
const path = Astro.url.pathname;
const onHome = path === base || path === base.slice(0, -1) || path === '/';
const sect = (hash: string) => (onHome ? hash : `${base}${hash}`);

const links = [
  { label: 'Features', href: sect('#features') },
  { label: 'Performance', href: sect('#performance') },
  { label: 'Architecture', href: sect('#architecture') },
  { label: 'Download', href: sect('#download') },
];

// Fetched at build time; falls back gracefully to a "Star" label.
const stars = await fetchStars();
const starLabel = stars && stars > 0 ? formatStars(stars) : 'Star';
---

<header
  data-nav
  class="fixed inset-x-0 top-0 z-50 transition-[background,box-shadow] duration-300"
>
  <nav
    class="mx-auto flex h-[var(--nav-h)] max-w-7xl items-center justify-between gap-4 px-5 sm:px-8"
  >
    <!-- Brand -->
    <a href={import.meta.env.BASE_URL} class="group flex items-center gap-2.5" aria-label="Musa CAD home">
      <img
        src={`${import.meta.env.BASE_URL}icon-192.png`}
        alt=""
        width="30"
        height="30"
        class="h-[30px] w-[30px] transition-transform duration-300 group-hover:rotate-[-6deg]"
      />
      <span class="font-display text-[1.15rem] font-semibold tracking-tight">
        Musa<span class="text-accent">CAD</span>
      </span>
    </a>

    <!-- Center nav (desktop) -->
    <ul class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="rounded-lg px-3 py-2 text-sm text-ink-soft transition-colors hover:text-ink"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-1.5 rounded-lg border border-line-strong bg-paper-2 px-3 py-2 text-sm text-ink transition-colors hover:border-ink/30 sm:inline-flex"
        aria-label="MusaCAD on GitHub"
      >
        <svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-ink-faint" fill="currentColor" aria-hidden="true">
          <path d="m12 17.27 5.18 3.13-1.37-5.9 4.59-3.98-6.06-.52L12 4.5 9.66 9.99 3.6 10.51l4.59 3.98-1.37 5.9z"></path>
        </svg>
        <span class="font-mono text-xs">{starLabel}</span>
      </a>

      <a
        href={RELEASES_URL}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-1.5 rounded-lg border border-line-strong bg-paper-2 px-3 py-2 text-sm text-ink transition-colors hover:border-ink/30 lg:inline-flex"
      >
        Releases
        <span class="font-mono text-[0.7rem] text-ink-faint">{LATEST_RELEASE}</span>
      </a>

      <a
        href={`${base}donate`}
        class="btn btn-accent px-3.5 py-2 text-sm"
        aria-label="Support Musa CAD"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M12 21s-6.7-4.35-9.33-8.07C.9 10.3 1.27 6.9 3.8 5.4c1.98-1.17 4.3-.5 5.62 1.08L12 9l.6-.6c1.32-1.58 3.64-2.25 5.62-1.08 2.53 1.5 2.9 4.9 1.11 7.53C18.7 16.65 12 21 12 21Z"></path>
        </svg>
        Donate
      </a>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        data-menu-toggle
        class="ml-1 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-line-strong bg-paper-2 md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div
    data-menu
    class="hidden border-t border-line bg-paper/95 px-5 py-3 backdrop-blur md:hidden"
  >
    <ul class="flex flex-col gap-1">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="block rounded-lg px-3 py-2.5 text-sm text-ink-soft hover:bg-panel">
              {l.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href={REPO_URL} target="_blank" rel="noopener" class="block rounded-lg px-3 py-2.5 text-sm text-ink-soft hover:bg-panel">
          GitHub
        </a>
      </li>
      <li>
        <a href={RELEASES_URL} target="_blank" rel="noopener" class="block rounded-lg px-3 py-2.5 text-sm text-ink-soft hover:bg-panel">
          Releases · {LATEST_RELEASE}
        </a>
      </li>
      <li>
        <a href={`${base}donate`} class="block rounded-lg px-3 py-2.5 text-sm font-medium text-accent hover:bg-panel">
          Donate ♥
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // --- Glass-on-scroll ---
  const nav = document.querySelector('[data-nav]');
  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle('nav-glass', window.scrollY > 8);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // --- Mobile menu ---
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-menu]');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }),
  );
</script>
