---
// PERFORMANCE — "measured, not marketed". Count-up stat blocks (animated when
// scrolled into view) drawn straight from the verbatim benchmark numbers, each
// dressed with a thin CAD dimension-line detail. Beside them sits a small
// inline-SVG viz: a high/flat FPS trace holding steady near 144 while a separate
// "edit activity" bar spikes — the picture of "pan/zoom uploads zero scene bytes;
// FPS stays smooth independent of edit activity".
import SectionHeading from './SectionHeading.astro';

// Stat blocks. `to` is the count-up target; non-numeric finals (the "4–6" and
// "420–490" ranges) are handled with `display` so they read exactly as written.
const stats = [
  {
    key: 'hz',
    to: 144,
    prefix: '',
    suffix: ' Hz+',
    label: 'viewport refresh target',
    dim: '@target',
  },
  {
    key: 'prims',
    to: 1_000_000,
    prefix: '',
    suffix: '',
    label: 'primitives per scene',
    dim: '1e6',
  },
  {
    key: 'draws',
    to: 6,
    display: '4–6',
    prefix: '~',
    suffix: '',
    label: 'draw calls',
    dim: 'instanced',
  },
  {
    key: 'insert',
    to: 32,
    prefix: '~',
    suffix: ' ns / line',
    label: 'insert one line',
    dim: '1e6 ≈ 32 ms',
  },
  {
    key: 'fps',
    to: 490,
    display: '420–490',
    prefix: '',
    suffix: ' FPS',
    label: 'measured offscreen · UHD 630 / Mesa',
    dim: 'offscreen',
  },
];
---

<section id="performance" class="mx-auto max-w-7xl px-5 py-24 sm:px-8 sm:py-28">
  <SectionHeading
    eyebrow="MEASURED, NOT MARKETED"
    titleHtml='Numbers that hold at <span class="text-accent">144&#8202;Hz.</span>'
  >
    <p class="mt-4 text-lg text-ink-soft">
      Every figure below is observed, not aspirational — a data-oriented core and a
      GPU viewport that uploads
      <span class="text-ink">zero scene bytes</span> on pan and zoom.
    </p>
  </SectionHeading>

  <div class="mt-14 grid gap-10 lg:grid-cols-[1.15fr_1fr] lg:gap-12">
    <!-- ======================= LEFT: count-up stat blocks ====================== -->
    <ul
      data-perf-stats
      class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2"
    >
      {
        stats.map((s) => (
          <li class="relative bg-paper-2 p-6 sm:p-7">
            {/* dimension tick — top-left corner detail */}
            <span
              class="absolute left-0 top-0 h-3 w-px bg-line-strong"
              aria-hidden="true"
            />
            <span
              class="absolute left-0 top-0 h-px w-3 bg-line-strong"
              aria-hidden="true"
            />

            {/* big number — display font, mono unit */}
            <p class="font-display text-4xl font-semibold leading-none text-ink sm:text-5xl">
              <span class="text-ink-faint">{s.prefix}</span>
              <span
                data-count
                data-to={s.to}
                data-display={s.display ?? ''}
                class="tabular-nums"
              >
                {/* reduced-motion / no-JS fallback: final value rendered inline */}
                {s.display ?? s.to.toLocaleString('en-US')}
              </span>
              <span class="font-mono text-base font-medium text-ink-soft sm:text-lg">
                {s.suffix}
              </span>
            </p>

            {/* label */}
            <p class="mt-3 text-sm text-ink-soft">{s.label}</p>

            {/* thin dimension line with arrowheads + a mono note */}
            <div
              class="mt-4 flex items-center gap-1.5 font-mono text-[0.66rem] text-ink-faint"
              aria-hidden="true"
            >
              <span>◄</span>
              <span class="h-px flex-1 bg-line" />
              <span class="whitespace-nowrap">{s.dim}</span>
              <span class="h-px flex-1 bg-line" />
              <span>►</span>
            </div>
          </li>
        ))
      }

      {/* trailing cell keeps the 2-col grid tidy with 5 odd stats */}
      <li
        class="relative hidden bg-paper-2 p-6 sm:block sm:p-7"
        aria-hidden="true"
      >
        <span class="absolute left-0 top-0 h-3 w-px bg-line-strong"></span>
        <span class="absolute left-0 top-0 h-px w-3 bg-line-strong"></span>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-ink-faint">
          1,000,000 lines
        </p>
        <p class="mt-3 text-sm text-ink-soft">
          inserted in
          <span class="font-mono text-ink">~32 ms</span> — cache-friendly
          Structure-of-Arrays, no virtual dispatch on the hot path.
        </p>
        <div class="mt-4 flex items-center gap-1.5">
          <span class="inline-block h-2 w-2 rotate-45 border border-accent-2"></span>
          <span class="font-mono text-[0.66rem] text-accent-2">SoA · generational handles</span>
        </div>
      </li>
    </ul>

    <!-- ===================== RIGHT: FPS-stays-flat viz ====================== -->
    <figure class="flex flex-col">
      <div
        class="crop-frame relative overflow-hidden rounded-2xl border border-line-strong bg-paper-2 shadow-[0_30px_80px_-40px_rgba(20,24,30,0.4)]"
      >
        <!-- chrome bar -->
        <div
          class="flex items-center justify-between gap-3 border-b border-line bg-panel px-3.5 py-2.5"
        >
          <span class="font-mono text-[0.72rem] text-ink-faint">render vs. edit · 1.0 s window</span>
          <div class="flex items-center gap-1.5">
            <span class="cad-chip" data-on>
              <span data-fps-readout>144</span> FPS
            </span>
          </div>
        </div>

        <!-- the chart -->
        <div class="px-4 py-5 sm:px-5">
          <!--
            viewBox 0..320 wide, 0..160 tall. Two lanes:
            • top lane (y≈20..70): the FPS trace — held high and nearly flat.
            • bottom lane (y≈95..150): "edit activity" bars that spike.
            Animated with GSAP (subtle, looping). Reduced motion freezes a frame.
          -->
          <svg
            data-perf-viz
            viewBox="0 0 320 160"
            class="block h-auto w-full"
            role="img"
            aria-label="A render frame-rate trace stays high and flat near 144 Hz while a separate edit-activity bar spikes, showing the viewport speed is independent of edit bursts."
          >
            <!-- blueprint baseline grid -->
            <g stroke="currentColor" class="text-grid" stroke-width="0.75" opacity="0.5">
              <line x1="0" y1="20" x2="320" y2="20"></line>
              <line x1="0" y1="45" x2="320" y2="45"></line>
              <line x1="0" y1="70" x2="320" y2="70"></line>
            </g>

            <!-- 144 reference line (accent-2 / green snap colour) -->
            <line
              x1="0" y1="24" x2="320" y2="24"
              stroke="currentColor" class="text-accent-2"
              stroke-width="1" stroke-dasharray="3 4" opacity="0.8"
            ></line>
            <text x="4" y="17" class="fill-accent-2 font-mono" font-size="9">144 Hz target</text>

            <!-- FPS trace: stays high & flat, only micro-jitter. Drawn in accent. -->
            <path
              data-fps-line
              d="M0,26 L40,25 L80,27 L120,25 L160,26 L200,25 L240,27 L280,25 L320,26"
              fill="none" stroke="currentColor" class="text-accent"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            ></path>

            <!-- divider between lanes -->
            <line x1="0" y1="84" x2="320" y2="84" stroke="currentColor" class="text-line" stroke-width="1"></line>
            <text x="4" y="80" class="fill-current text-ink-faint font-mono" font-size="8">FPS</text>
            <text x="4" y="98" class="fill-current text-ink-faint font-mono" font-size="8">EDIT ACTIVITY</text>

            <!-- edit-activity bars: mostly low, occasional sharp spikes. -->
            <g data-edit-bars fill="currentColor" class="text-ink-soft">
              <rect x="8"   y="146" width="10" height="4"></rect>
              <rect x="30"  y="146" width="10" height="4"></rect>
              <rect x="52"  y="146" width="10" height="4"></rect>
              <rect x="74"  y="146" width="10" height="4"></rect>
              <rect x="96"  y="146" width="10" height="4"></rect>
              <rect x="118" y="146" width="10" height="4"></rect>
              <rect x="140" y="146" width="10" height="4"></rect>
              <rect x="162" y="146" width="10" height="4"></rect>
              <rect x="184" y="146" width="10" height="4"></rect>
              <rect x="206" y="146" width="10" height="4"></rect>
              <rect x="228" y="146" width="10" height="4"></rect>
              <rect x="250" y="146" width="10" height="4"></rect>
              <rect x="272" y="146" width="10" height="4"></rect>
              <rect x="294" y="146" width="10" height="4"></rect>
            </g>

            <!-- "0 bytes" marker that pulses on a spike -->
            <g data-zero-bytes opacity="0">
              <rect x="232" y="92" width="74" height="14" rx="2"
                fill="currentColor" class="text-accent-soft"></rect>
              <text x="238" y="102" class="fill-accent-press font-mono" font-size="8">upload: 0 bytes</text>
            </g>
          </svg>
        </div>
      </div>

      <!-- caption (verbatim idea) -->
      <figcaption class="mt-4 flex items-start gap-2 text-sm text-ink-soft">
        <span
          class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rotate-45 bg-accent-2"
          aria-hidden="true"
        ></span>
        <span>
          Pan and zoom upload <span class="text-ink">zero scene bytes</span> — the
          frame-rate stays smooth, independent of edit activity.
        </span>
      </figcaption>
    </figure>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---------------------------------------------------------------- count-ups
  const counters = gsap.utils.toArray<HTMLElement>('[data-count]');

  function renderCount(el: HTMLElement, value: number) {
    const display = el.dataset.display;
    if (display) {
      // ranges ("4–6", "420–490") read verbatim once animation completes
      el.textContent = display;
    } else {
      el.textContent = Math.round(value).toLocaleString('en-US');
    }
  }

  if (reduced) {
    // Reduced motion: final values are already in the markup; nothing to animate.
    counters.forEach((el) => {
      const to = Number(el.dataset.to || 0);
      renderCount(el, to);
    });
  } else {
    // Mid-count, ranges should tick up too — drive them off the same target.
    counters.forEach((el) => {
      const to = Number(el.dataset.to || 0);
      const obj = { v: 0 };
      el.textContent = el.dataset.display ? '0' : '0';
      gsap.to(obj, {
        v: to,
        duration: 1.6,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        onUpdate: () =>
          (el.textContent = el.dataset.display
            ? // for ranges, count the upper bound then snap to the verbatim text
              Math.round(obj.v).toLocaleString('en-US')
            : Math.round(obj.v).toLocaleString('en-US')),
        onComplete: () => renderCount(el, to),
      });
    });
  }

  // ----------------------------------------------------------------- the viz
  const viz = document.querySelector<SVGSVGElement>('[data-perf-viz]');
  const fpsLine = document.querySelector<SVGPathElement>('[data-fps-line]');
  const bars = gsap.utils.toArray<SVGRectElement>('[data-edit-bars] rect');
  const zeroBytes = document.querySelector<SVGGElement>('[data-zero-bytes]');
  const fpsReadout = document.querySelector<HTMLElement>('[data-fps-readout]');

  // Flat baseline (held high near "144"). Each point jitters only slightly so
  // the trace clearly stays flat regardless of what the edit lane does.
  const baseY = [26, 25, 27, 25, 26, 25, 27, 25, 26];

  function flatPath(jitter: number) {
    const xs = [0, 40, 80, 120, 160, 200, 240, 280, 320];
    return xs
      .map((x, i) => {
        const y = baseY[i] + (Math.random() - 0.5) * jitter;
        return `${i === 0 ? 'M' : 'L'}${x},${y.toFixed(1)}`;
      })
      .join(' ');
  }

  if (!reduced && viz && fpsLine) {
    // Subtle looping micro-jitter on the FPS trace — it visibly stays flat/high.
    gsap.to(
      {},
      {
        duration: 0.9,
        repeat: -1,
        ease: 'none',
        onRepeat: () => fpsLine.setAttribute('d', flatPath(2.2)),
        scrollTrigger: { trigger: viz, start: 'top 90%' },
      },
    );

    // Edit-activity lane: bars mostly idle, with periodic sharp spikes. The
    // FPS trace above is intentionally untouched by this timeline.
    const spike = gsap.timeline({
      repeat: -1,
      repeatDelay: 0.6,
      scrollTrigger: { trigger: viz, start: 'top 90%' },
    });

    // pick a few bars to spike hard, the rest stay low
    const spikeIndexes = [3, 9, 11];
    bars.forEach((bar, i) => {
      const isSpike = spikeIndexes.includes(i);
      const h = isSpike ? 48 + Math.random() * 8 : 3 + Math.random() * 5;
      spike.to(
        bar,
        {
          attr: { y: 150 - h, height: h },
          duration: 0.18,
          ease: 'power2.out',
        },
        i * 0.05,
      );
      // settle back down
      spike.to(
        bar,
        { attr: { y: 146, height: 4 }, duration: 0.4, ease: 'power2.in' },
        i * 0.05 + 0.5,
      );
    });

    // "upload: 0 bytes" tag pulses in time with the biggest spike.
    if (zeroBytes) {
      spike.to(zeroBytes, { opacity: 1, duration: 0.2 }, 0.55);
      spike.to(zeroBytes, { opacity: 0, duration: 0.3 }, 1.4);
    }

    // FPS chip readout flickers within a tight high band (144–146) — never dips.
    if (fpsReadout) {
      gsap.to(
        {},
        {
          duration: 0.5,
          repeat: -1,
          ease: 'none',
          onRepeat: () =>
            (fpsReadout.textContent = String(144 + Math.floor(Math.random() * 3))),
          scrollTrigger: { trigger: viz, start: 'top 90%' },
        },
      );
    }
  }
  // Reduced motion: the SVG already renders a representative static frame
  // (flat high FPS line + low edit bars), so no fallback work is needed.
</script>
